# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo

# 虚拟环境
.venv
venv/
env/
ENV/
env.bak/
venv.bak/

# 环境变量（含 API Key，绝对不能提交）
.env

# SQLite 数据库（运行时生成的对话历史，不属于代码）
*.db
*.db-shm
*.db-wal

# LangGraph Studio 运行时状态（本地调试缓存，不属于代码）
.langgraph_api/

# Pickle 序列化文件（运行时产物）
*.pckl

# IDE
.vscode/
.idea/

# 二进制媒体文件
*.png
*.jpg
*.jpeg

# FastEmbed 模型缓存（首次运行自动下载，体积大，不属于代码）
fastembed_cache/

# 前端构建产物（npm run build 生成，可从源码重建）
agent_lab/static/

# 前端依赖（npm install 生成）
frontend/node_modules/

# Vite 构建缓存
frontend/.vite/
frontend/dist/

# Gemini session data
.gemini/

