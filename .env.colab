# ============================================================
# 蜃景 × Colab 单机本地配置（全部走 localhost，不再 SSH/远程）
# 用法：在 Colab 把本文件复制成 .env（cp .env.colab .env），填好 OPENAI_API_KEY 即可。
# 迁 Colab 不用改代码：出图/出片透明走本机 ComfyUI；SSH 分支因 GPU_SSH_HOST 留空而睡着。
# ============================================================

# ── LLM（必需：Agent 决策/拆分镜/旁白）──────────────────────
OPENAI_API_KEY=sk-填你的-deepseek-key
OPENAI_API_BASE=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat

# ── ComfyUI 本机端点（总开关；空=禁用 ComfyUI）──────────────
COMFYUI_BASE_URL=http://127.0.0.1:8188

# ── 出图/出片透明走本机 ComfyUI ─────────────────────────────
# 注意：值后面不要写行内注释！有些解析器会把 "flux # ..." 整段当成值，导致 != "flux" 而回退 SSH。
# COMFYUI_IMAGE_AS=flux  → 出图走 ComfyUI t2i（默认空=走 FLUX-SSH）
COMFYUI_IMAGE_AS=flux
# COMFYUI_VIDEO_AS=auto  → 出片跟随 VIDEO_PROVIDER_DEFAULT
COMFYUI_VIDEO_AS=auto
# VIDEO_PROVIDER_DEFAULT=wan2.2  → 出片用 Wan2.2（配合 auto 走 i2v 模板）
VIDEO_PROVIDER_DEFAULT=wan2.2
IMAGE_PROVIDER_DEFAULT=flux

# ── i2v 用 Wan2.2-I2V-A14B 双专家 —— 默认 fp16 原生满精度(A100-80G 免量化,画质最高;5B 已弃)──
# 路径相对后端启动目录（notebook 里 cd 到仓库根再起 uvicorn）。
# 80G A100 用 fp16(本行,各 ~28G,免任何量化);
#   40G A100 显存不够 → 改 i2v_fp8_template.json(fp8_scaled,A100 原生FP8 免反量化,各 ~14G);
#   <24G 小卡才用 i2v_gguf_template.json(逐步反量化、慢)。
# 换档要同步:按 colab/download_models.sh 里注释取消/启用对应档的权重下载。
COMFYUI_WORKFLOW_I2V=comfyui_workflows/i2v_bf16_template.json
# t2i/s2v 留空=用仓库自带 flux 模板（含 LoraLoader，人物 LoRA 自动接入）

# ── 原生最强出片（A100）：守住 720p 竖屏（A14B 模板内步数已 30）──
COMFYUI_SIZE=720*1280

# ── 出片画质（Wan2.2 必备 ModelSamplingSD3 shift；模板已内置该节点，值在这调）──
#   画面糊/细节不足 → 调大到 8；运动僵硬/太慢 → 调小到 3。720p 官方默认=5。
#   （负向词走 config 的官方 WAN_VIDEO_NEGATIVE；CFG=3.5 / 采样器 euler+simple 已写进模板，一般不用动。）
WAN_SHIFT=5.0

# ── 出片时长/步数 ──────────────────────────────────────────────
# 帧数须 4n+1、@16fps：81=5.0s(原生最佳) / 97≈6.1s / 49≈3.1s(草稿)。更长用面板「接续段数」拼接多段。
COMFYUI_FRAMES=81
COMFYUI_FPS=16
# 步数：30=精修；草稿可降 20(再快 ~1.5×)。模板已把步数/双专家切换点做成可配。
COMFYUI_STEPS=30
# ★快/精切换：草稿走量 → COMFYUI_SIZE=480*832(~2.5×快)+COMFYUI_STEPS=20；成片 → 720p/30步。
#   也可在出片面板「分辨率」下拉逐镜一键切 480快/720精，不用改这里。

# ── 画质增强:成片再过一道 RealESRGAN_x2 放大(更清更锐,720p→1440p;每镜 +约1-2分,失败保原片)──
# 默认关。嫌糊/想更锐就取消下行注释启用(RealESRGAN 模型 download 已下好):
# COMFYUI_WORKFLOW_POST=comfyui_workflows/post_upscale_template.json

# ── (可选) LTX-Video 2.3：与 Wan2.2 并列的「快/音视频一体」出片档(面板模型下拉里手选，参数各自对应) ──
# ★前提：LTX 2.3 需 ComfyUI v0.16+(强制 torch≥2.4)；本仓默认 ComfyUI 钉 v0.3.75 跑不了，两者不能同实例共存。
# 启用步骤(默认全关，不影响现有 Wan 链路)：
#   ① setup 前: export COMFY_REF=v0.16.1(或更高) + 确保 torch≥2.4 → 重跑 setup.sh
#   ② setup/download 前: export SETUP_LTX=1  export DOWNLOAD_LTX=1
#   ③ 取消下面注释 LTX2_ENABLED=true
#   ④ 首跑前按 ComfyUI v0.16+ 官方模板核对 comfyui_workflows/ltx_i2v_template.json(脚手架)
# 开了之后 Wan2.2 与 LTX-Video 2.3 一起出现在模型下拉，逐镜可选；LTX 卡是 LTX 专属参数(档位/8n+1/32倍数/guidance)。
# LTX2_ENABLED=true
# COMFYUI_WORKFLOW_LTX=comfyui_workflows/ltx_i2v_template.json
# 单实例(默认):LTX 与 Wan 共用同一个 ComfyUI(留空即可)。双实例:LTX 单开一个 v0.16+ 端点,填它的地址：
# COMFYUI_LTX_BASE_URL=http://127.0.0.1:8189
# LTX2_SIZE=704*1280
# LTX2_FRAMES=121
# LTX2_FPS=24
# LTX2_STEPS=30
# LTX2_GUIDANCE=3.0
# LTX2_DISTILLED=false
# LTX2_KEEP_AUDIO=false

# ── 极速档(Wan2.2-Lightning 4步蒸馏 LoRA;~1-2分/镜,画质≈A14B 略降)──────────
# false=默认精修(A14B 满档 30步);true=默认极速。出片面板「更多参数→极速档」可逐镜切,不必改这里。
# LoRA 由 download_models.sh 自动下到 loras/(高/低噪各一,文件名见 config，一般不用改)。
WAN_LIGHTNING=false
# 极速档若运动太弱/慢动作 → 取消下行注释把高噪强度调到 1.5(★别降、别动 low;0.65-0.8 是 T2V 的,i2v 会更不动):
# WAN_LIGHTNING_STR_HIGH=1.5

# ── 接续段拼接接缝平滑(只在 segments≥2 生效;单段 81帧/5s 无缝隙)──────────────
# 相邻段交叉淡化秒数:0=硬拼(尾帧续接会有运动跳/色闪);0.2≈3帧淡化,通常净改善。
VIDEO_SEAM_CROSSFADE=0.2

# ── 关掉 SSH / 远程（留空即彻底不走远程）────────────────────
GPU_SSH_HOST=

# ── 产物落地（Linux 路径；挂 Drive 可持久化：/content/drive/MyDrive/cael_video_out）──
NP2V_LOCAL_OUT=/content/cael_video_out

# ── A14B 双专家 720p/30步 更慢，出片超时给足（秒）──────────────
COMFYUI_TIMEOUT=1800

# ── 英文短剧：出图 prompt 我们直接写英文，自动翻译留开也无害 ──
IMAGE_PROMPT_AUTOTRANSLATE=True

# ── （可选）LoRA 训练后端：Colab 训练服务隧道地址；留空=训练在 notebook 里手动跑 ──
# LORA_TRAIN_ENDPOINT=
# PUBLIC_BASE_URL=                # 蜃景 对 Colab 可达的公网地址（供训练服务回拉参考图）

# ── 出图底模：FLUX-dev 系（含无审查 Fluxed Up 等微调/合并）。仅原创虚构成年角色，遵守合规前置。──
# 换别的 FLUX 底模：notebook 第 1 格设 FLUX_BASE_REPO/FILE(HF) 或 FLUX_BASE_URL/FILE(Civitai 直链)；
# 第 6 格会按 FLUX_BASE_KIND/FILE 自动覆盖下面 COMFYUI_FLUX_UNET，一般只在第 1 格改即可。
# 当前默认：DAC_Fluxed_Style（CivitAI 的 FLUX UNET-only 底模）。出图走自带 flux 模板(UNETLoader+DualCLIP+VAE)。
COMFYUI_FLUX_UNET=fluxed-up.safetensors
COMFYUI_WORKFLOW_T2I=
# (真·全合一 checkpoint 才用：COMFYUI_FLUX_CKPT=xxx.safetensors + COMFYUI_WORKFLOW_T2I=comfyui_workflows/t2i_checkpoint_template.json)

# ── 人物 LoRA 训练底模（★与出图的 FLUX 不同源！出片引擎是 Wan2.2 视频模型，LoRA 必须训在 Wan 上）──
# diffusers 格式（ai-toolkit 读）。t2v LoRA 用下面这个仓库 id，ai-toolkit 首次训练自动下载（~56G）。
# 想免重下/持久：先跑 LW1 下到 Drive，再把本行改成那个本地路径（如 /content/drive/MyDrive/mirage_tools/wan22_t2v_diffusers）。
LORA_TRAIN_BASE=ai-toolkit/Wan2.2-T2V-A14B-Diffusers-bf16
# i2v 原生 LoRA（续接锁脸用，需视频数据集）默认 ai-toolkit/Wan2.2-I2V-A14B-Diffusers-bf16；要改取消下行注释：
# LORA_TRAIN_I2V_BASE=ai-toolkit/Wan2.2-I2V-A14B-Diffusers-bf16

# ── 训练提速旋钮（可选；不设走自适应默认。OOM 就调回更省显存的一档）─────────────────
# 默认（auto）：≥90G 大卡免量化用 bf16；A100-80G 保守开量化、开梯度检查点、带 1024 桶（稳但偏慢）。
# A100-80G 想提速，推荐先开这两个（安全、提速明显）：
# LORA_TRAIN_NETWORK_DIM=32     # rank 64→32：略快 + 省显存（脸细节小降）
# LORA_TRAIN_HIRES=false        # 去掉 1024 分辨率桶：快~40%（脸高频细节略降；想保脸就别开）
# 更激进（有显存余量再试，OOM 就注释回去）：
# LORA_TRAIN_QUANTIZE=false     # bf16 底模、免反量化开销（80G 装得下 ~56G）
# LORA_TRAIN_GRAD_CKPT=false    # 关梯度检查点：快~25%（配合 HIRES=false 更稳）
# 别大降步数：LORA_TRAIN_STEPS 默认 3000，降到 2000 易"神似不形似"，最多到 ~2500。
