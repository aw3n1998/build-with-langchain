# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# DeepSeek API（默认使用）
OPENAI_API_KEY=your_deepseek_key_here
OPENAI_API_BASE=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat

# 如果要切换到 OpenAI，修改如下：
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_API_BASE=https://api.openai.com/v1
# MODEL_NAME=gpt-4o

# 切换到 OpenRouter（OpenAI 兼容；全体 agent 都走它，包括分镜）——改这三行即可：
# OPENAI_API_KEY=sk-or-v1-你的key       # ★只填到本地 .env，绝不提交;泄露过的 key 立刻去 OpenRouter 吊销重发
# OPENAI_API_BASE=https://openrouter.ai/api/v1
# MODEL_NAME=x-ai/grok-4.20            # 其它见 https://openrouter.ai/x-ai (grok-4 / grok-4.1-fast / grok-4.3 ...)
# OPENROUTER_REFERER=https://你的站点   # 可选(排行/部分免费模型用)；OPENROUTER_TITLE 默认 Mirage

# 只想【分镜用 grok、聊天仍 DeepSeek】= 上面三行保持 DeepSeek，另填分镜专属(未填字段回退上面通用)：
# STORYBOARD_API_KEY=sk-or-v1-你的key   # ★同样只入本地 .env / Colab Secret，不提交
# STORYBOARD_API_BASE=https://openrouter.ai/api/v1
# STORYBOARD_MODEL=x-ai/grok-4.20

# ── 小说转视频流水线 / 远程 GPU（可选，未配置时 video agent 仅离线编排） ──
# GPU 服务器 SSH（跑 FLUX 出图 + Wan2.2 图生视频）
GPU_SSH_HOST=
GPU_SSH_PORT=22
GPU_SSH_USER=root
# 私钥路径优先；或填密码二选一
GPU_SSH_KEY_PATH=
GPU_SSH_PASSWORD=
# 服务器端路径（默认值对应 AutoDL 4090 环境）
GPU_PYTHON=/root/autodl-tmp/miniconda3/bin/python
GPU_WAN_REPO=/root/autodl-tmp/Wan2.2
GPU_WAN_CKPT=/root/autodl-tmp/models/Wan-AI/Wan2.2-I2V-A14B
GPU_OUTPUT_DIR=/root/autodl-tmp/pipeline_out
GPU_SCENES_DIR=/root/autodl-tmp/cael_scenes
# FLUX 多候选出图（脚本随仓库携带、首次自动上传；多种子出 N 张供选图）
GPU_FLUX_CANDIDATES_SCRIPT=/root/autodl-tmp/flux_candidates.py
# 出图底模；NSFW 直接指向无审查模型即可。A100 推荐 lodestones/Chroma（无审查 FLUX 系，
# 注意人物 LoRA 需按 Chroma 重训）；要 FLUX-dev 人物 LoRA 直接生效则用 FLUX-dev 系无审查合并。
GPU_FLUX_BASE=/root/autodl-tmp/models/flux-dev
GPU_FLUX_LORA=/root/autodl-tmp/output/cael_flux_lora_v1/cael_flux_lora_v1.safetensors
GPU_FLUX_OUT_ROOT=/root/autodl-tmp/flux_candidates_out
FLUX_N=4
FLUX_STEPS=28
FLUX_GUIDANCE=3.5
FLUX_WIDTH=768
FLUX_HEIGHT=1024
FLUX_OFFLOAD=model
# ── ComfyUI t2i 出图底模（走 ComfyUI/HTTP 时生效；默认已切无审查 Chroma1-HD）──
# Chroma 架构异于 flux-dev（单 T5 + 真 CFG），必须配套专用模板，不能只改底模文件名。
# 值后面别写行内注释，免得被当成值的一部分。
COMFYUI_FLUX_UNET=Chroma1-HD.safetensors
COMFYUI_WORKFLOW_T2I=comfyui_workflows/t2i_chroma_template.json
LORA_TRAIN_BASE=lodestones/Chroma1-HD
# Wan2.2-I2V-A14B 原生最强出片（A100；5B 已弃用）。守住原生 720p 级分辨率，别盲目超分。
WAN_SIZE=704*1280
WAN_FRAME_NUM=81
WAN_SAMPLE_STEPS=30
# 本机产物 / 状态库落地
NP2V_DB_PATH=
NP2V_LOCAL_OUT=
