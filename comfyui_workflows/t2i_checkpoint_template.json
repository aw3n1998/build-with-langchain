{
  "10": {
    "class_type": "CheckpointLoaderSimple",
    "_meta": {
      "title": "全合一底模（%CKPT% 由后端注入）",
      "note": "CivitAI 风格的 FLUX 全合一 checkpoint（内含 UNET+CLIP+VAE，如 Fluxed Up）。放在 ComfyUI/models/checkpoints/。与 t2i_template.json(UNET-only) 的区别：用 CheckpointLoaderSimple 一个节点出 MODEL/CLIP/VAE，不再单独 DualCLIPLoader/VAELoader。节点编号沿用(10=底模/13=LoRA)，未配 LoRA 时后端 _strip_lora_node 通用删节点13并把引用回退到 13 自己的 model/clip 来源。占位符同 comfyui_image.py。"
    },
    "inputs": {
      "ckpt_name": "%CKPT%"
    }
  },
  "13": {
    "class_type": "LoraLoader",
    "_meta": { "title": "人物 LoRA（%LORA% 由后端按项目注入；无 LoRA 时本节点被自动删除）" },
    "inputs": {
      "lora_name": "%LORA%",
      "strength_model": 1.0,
      "strength_clip": 1.0,
      "model": ["10", 0],
      "clip": ["10", 1]
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "正向提示" },
    "inputs": { "text": "%PROMPT%", "clip": ["13", 1] }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "负向提示" },
    "inputs": { "text": "%NEG_PROMPT%", "clip": ["13", 1] }
  },
  "22": {
    "class_type": "FluxGuidance",
    "inputs": { "guidance": 3.5, "conditioning": ["6", 0] }
  },
  "5": {
    "class_type": "EmptySD3LatentImage",
    "inputs": { "width": "%WIDTH%", "height": "%HEIGHT%", "batch_size": 1 }
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "%SEED%",
      "steps": "%STEPS%",
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["13", 0],
      "positive": ["22", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["3", 0], "vae": ["10", 2] }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "mirage_t2i", "images": ["8", 0] }
  }
}
