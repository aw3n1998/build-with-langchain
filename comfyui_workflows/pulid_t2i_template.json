{
  "10": {
    "class_type": "UNETLoader",
    "_meta": { "title": "底模 UNET(与出图/训练同源) %UNET%" },
    "inputs": { "unet_name": "%UNET%", "weight_dtype": "default" }
  },
  "11": {
    "class_type": "DualCLIPLoader",
    "_meta": { "title": "文本编码器 t5xxl + clip_l(flux)" },
    "inputs": {
      "clip_name1": "t5xxl_fp16.safetensors",
      "clip_name2": "clip_l.safetensors",
      "type": "flux"
    }
  },
  "12": {
    "class_type": "VAELoader",
    "_meta": { "title": "VAE ae(flux)" },
    "inputs": { "vae_name": "ae.safetensors" }
  },
  "30": {
    "class_type": "PulidFluxModelLoader",
    "_meta": { "title": "PuLID-Flux 模型(需装 ComfyUI_PuLID_Flux_ll)" },
    "inputs": { "pulid_file": "%PULID_MODEL%" }
  },
  "31": { "class_type": "PulidFluxEvaClipLoader", "inputs": {} },
  "32": {
    "class_type": "PulidFluxInsightFaceLoader",
    "inputs": { "provider": "CUDA" }
  },
  "33": {
    "class_type": "LoadImage",
    "_meta": { "title": "参考脸图(已上传到 ComfyUI input) %FACE%" },
    "inputs": { "image": "%FACE%" }
  },
  "34": {
    "class_type": "ApplyPulidFlux",
    "_meta": { "title": "把参考脸 ID 融进底模" },
    "inputs": {
      "weight": "%PULID_WEIGHT%",
      "start_at": 0.0,
      "end_at": 1.0,
      "model": ["10", 0],
      "pulid_flux": ["30", 0],
      "eva_clip": ["31", 0],
      "face_analysis": ["32", 0],
      "image": ["33", 0]
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "正向提示词 %PROMPT%" },
    "inputs": { "text": "%PROMPT%", "clip": ["11", 0] }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "负向提示词" },
    "inputs": { "text": "%NEG_PROMPT%", "clip": ["11", 0] }
  },
  "22": {
    "class_type": "FluxGuidance",
    "inputs": { "guidance": "%GUIDANCE%", "conditioning": ["6", 0] }
  },
  "5": {
    "class_type": "EmptySD3LatentImage",
    "inputs": { "width": "%WIDTH%", "height": "%HEIGHT%", "batch_size": 1 }
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "%SEED%",
      "steps": "%STEPS%",
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["34", 0],
      "positive": ["22", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["3", 0], "vae": ["12", 0] }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "mirage_pulid", "images": ["8", 0] }
  }
}
