{
  "_README": "FLUX 文生图模板 — API 格式。占位符 %PROMPT% %NEG_PROMPT% %WIDTH% %HEIGHT% %STEPS% %SEED%（可选 %LORA%）。节点13 LoraLoader 接入人物 LoRA：当项目/工作目录配了 flux_lora 时，comfyui_image.py 把 %LORA% 填成 loras 下的文件名；没配 LoRA 时 comfyui_image._strip_lora_node 会删掉节点13、把引用回退到 [10,0]/[11,0]，所以无 LoRA 也能正常出图。",
  "10": {
    "class_type": "UNETLoader",
    "inputs": { "unet_name": "flux1-dev.safetensors", "weight_dtype": "default" }
  },
  "11": {
    "class_type": "DualCLIPLoader",
    "inputs": { "clip_name1": "t5xxl_fp16.safetensors", "clip_name2": "clip_l.safetensors", "type": "flux" }
  },
  "13": {
    "class_type": "LoraLoader",
    "_meta": { "title": "人物 LoRA（%LORA% 由后端按项目注入；无 LoRA 时本节点被自动删除）" },
    "inputs": {
      "lora_name": "%LORA%",
      "strength_model": 1.0,
      "strength_clip": 1.0,
      "model": ["10", 0],
      "clip": ["11", 0]
    }
  },
  "12": {
    "class_type": "VAELoader",
    "inputs": { "vae_name": "ae.safetensors" }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "%PROMPT%", "clip": ["13", 1] }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "%NEG_PROMPT%", "clip": ["13", 1] }
  },
  "22": {
    "class_type": "FluxGuidance",
    "inputs": { "guidance": 3.5, "conditioning": ["6", 0] }
  },
  "5": {
    "class_type": "EmptySD3LatentImage",
    "inputs": { "width": "%WIDTH%", "height": "%HEIGHT%", "batch_size": 1 }
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "%SEED%",
      "steps": "%STEPS%",
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["13", 0],
      "positive": ["22", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["3", 0], "vae": ["12", 0] }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "agentlab_t2i", "images": ["8", 0] }
  }
}
