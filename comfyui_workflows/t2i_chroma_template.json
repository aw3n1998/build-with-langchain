{
  "10": {
    "class_type": "UNETLoader",
    "_meta": {
      "title": "Chroma 底模（%UNET% 由后端注入）",
      "note": "Chroma1-HD 文生图模板（无审查 FLUX 系，替代 flux-dev）。与 t2i_template.json 的关键区别：①文本编码器只用 T5（节点11 CLIPLoader type=chroma，不要 clip_l/DualCLIP）；②Chroma 是去蒸馏模型，用真 CFG+负向，故去掉 FluxGuidance、节点3 KSampler.cfg=4.0；③底模文件名由 %UNET%(=COMFYUI_FLUX_UNET) 注入。节点编号沿用 flux 模板(10=UNET/11=CLIP/13=LoRA)，以便后端 _strip_lora_node 在未配 LoRA 时删节点13、把引用回退到 10/11。占位符同 comfyui_image.py。"
    },
    "inputs": {
      "unet_name": "%UNET%",
      "weight_dtype": "default"
    }
  },
  "11": {
    "class_type": "CLIPLoader",
    "_meta": { "title": "T5-XXL（Chroma 只用 T5，type=chroma）" },
    "inputs": {
      "clip_name": "t5xxl_fp16.safetensors",
      "type": "chroma"
    }
  },
  "13": {
    "class_type": "LoraLoader",
    "_meta": { "title": "人物 LoRA（%LORA% 由后端按项目注入；无 LoRA 时本节点被自动删除）" },
    "inputs": {
      "lora_name": "%LORA%",
      "strength_model": 1.0,
      "strength_clip": 1.0,
      "model": ["10", 0],
      "clip": ["11", 0]
    }
  },
  "12": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "正向提示" },
    "inputs": {
      "text": "%PROMPT%",
      "clip": ["13", 1]
    }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "负向提示（Chroma 支持真负向）" },
    "inputs": {
      "text": "%NEG_PROMPT%",
      "clip": ["13", 1]
    }
  },
  "5": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {
      "width": "%WIDTH%",
      "height": "%HEIGHT%",
      "batch_size": 1
    }
  },
  "3": {
    "class_type": "KSampler",
    "_meta": { "title": "采样（Chroma：euler/beta，cfg=4.0 可调）" },
    "inputs": {
      "seed": "%SEED%",
      "steps": "%STEPS%",
      "cfg": 4.0,
      "sampler_name": "euler",
      "scheduler": "beta",
      "denoise": 1.0,
      "model": ["13", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["3", 0],
      "vae": ["12", 0]
    }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "mirage_t2i",
      "images": ["8", 0]
    }
  }
}
