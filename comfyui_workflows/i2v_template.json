{
  "37": {
    "class_type": "UNETLoader",
    "_meta": { "title": "模型(UNet) — 换成你的 Wan/GGUF 权重" },
    "inputs": { "unet_name": "wan2.2_ti2v_5B_fp16.safetensors", "weight_dtype": "default" }
  },
  "38": {
    "class_type": "CLIPLoader",
    "_meta": { "title": "文本编码器(CLIP/T5)" },
    "inputs": { "clip_name": "umt5_xxl_fp8_e4m3fn_scaled.safetensors", "type": "wan", "device": "default" }
  },
  "39": {
    "class_type": "VAELoader",
    "_meta": { "title": "VAE" },
    "inputs": { "vae_name": "wan2.2_vae.safetensors" }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "正向提示词 %PROMPT%" },
    "inputs": { "text": "%PROMPT%", "clip": ["38", 0] }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "负向提示词 %NEG_PROMPT%" },
    "inputs": { "text": "%NEG_PROMPT%", "clip": ["38", 0] }
  },
  "52": {
    "class_type": "LoadImage",
    "_meta": { "title": "参考图(首帧) %IMAGE%" },
    "inputs": { "image": "%IMAGE%", "upload": "image" }
  },
  "55": {
    "class_type": "WanImageToVideo",
    "_meta": { "title": "图生视频 i2v" },
    "inputs": {
      "positive": ["6", 0],
      "negative": ["7", 0],
      "vae": ["39", 0],
      "width": "%WIDTH%",
      "height": "%HEIGHT%",
      "length": "%FRAMES%",
      "batch_size": 1,
      "start_image": ["52", 0]
    }
  },
  "3": {
    "class_type": "KSampler",
    "_meta": { "title": "采样 KSampler" },
    "inputs": {
      "model": ["37", 0],
      "positive": ["55", 0],
      "negative": ["55", 1],
      "latent_image": ["55", 2],
      "seed": "%SEED%",
      "steps": "%STEPS%",
      "cfg": 5.0,
      "sampler_name": "uni_pc",
      "scheduler": "simple",
      "denoise": 1.0
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "_meta": { "title": "解码 VAEDecode" },
    "inputs": { "samples": ["3", 0], "vae": ["39", 0] }
  },
  "57": {
    "class_type": "VHS_VideoCombine",
    "_meta": { "title": "合成 mp4 (Video Helper Suite)" },
    "inputs": {
      "images": ["8", 0],
      "frame_rate": "%FPS%",
      "loop_count": 0,
      "filename_prefix": "agentlab_i2v",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 19,
      "pingpong": false,
      "save_metadata": true,
      "save_output": true
    }
  }
}
